rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{id} {
      allow read: if request.auth != null && request.auth.uid == id;
      allow create: if request.auth != null
        && request.auth.uid == id
        && request.resource.data.role == 'staff'
        && request.resource.data.requiresPasswordChange == false;
      allow update: if request.auth != null
        && request.auth.uid == id
        && request.resource.data.role == resource.data.role
        && request.resource.data.requiresPasswordChange == resource.data.requiresPasswordChange;
    }

    match /kegs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /kegNames/{id} {
      allow read, write: if request.auth != null;
    }

    match /movements/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        || (
          request.resource.data.kegId is string
          && request.resource.data.scanType == 'customer_request'
          && request.resource.data.type == 'customer_request'
          && request.resource.data.userId == 'customer'
          && request.resource.data.updatedBy == 'Customer'
          && request.resource.data.timestamp is string
        );
      allow update, delete: if false;
    }

    match /customerRequests/{id} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.kegId is string
        && request.resource.data.requestType in ['reorder', 'refill', 'replace']
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is string;
      allow update, delete: if request.auth != null;
    }

    match /locations/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
